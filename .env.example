# ─────────────────────────────────────────────────────────────────────────────
# DSDST Panel — Environment Variables
# Copy this file to .env and fill in the values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# JWT signing secret. Min 32 random characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_min_32_chars

# AES-256-GCM key used to encrypt third-party API keys at rest.
# Exactly 32 characters (padded/truncated automatically if not).
# Generate the same way as JWT_SECRET.
ENCRYPTION_SECRET=CHANGE_ME_32_chars

# HMAC secret used to hash Panel API keys before storing.
# Use a different value from ENCRYPTION_SECRET.
PANEL_API_HASH_SECRET=CHANGE_ME_panel_hash_secret


# ── Database ──────────────────────────────────────────────────────────────────

# Absolute path to the SQLite database file.
# Docker default: /data/dsdst_panel.db  (mounted as a named volume)
# Local default:  <project-root>/dsdst_panel.db  (omit to use default)
# DB_PATH=/data/dsdst_panel.db


# ── Network / CORS ────────────────────────────────────────────────────────────

# Public URL of this app (used for self-referential links, OAuth callbacks).
APP_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins.
# Leave empty (or omit) to allow all origins — safe behind a Cloudflare Tunnel
# or private network. Restrict this in production if exposed publicly.
# ALLOWED_ORIGINS=https://panel.yourdomain.com,https://yourdomain.com


# ── Optional integrations ─────────────────────────────────────────────────────

# Google Gemini AI API key — used for AI-assisted features.
# GEMINI_API_KEY=AIza...
